&CONTROL
    calculation = "scf"
    prefix      = "zn"
    restart_mode     = 'from_scratch'
    pseudo_dir  = '../'
    disk_io          = 'high'
    wfcdir           = './'
    wf_collect       = .true.
    tprnfor          = .true.
    tstress          = .true.


/

&SYSTEM
    a                         =  6.21436e+00
    c                         =  2.39280e+01
    degauss                   =  1.00000e-02
    ecutrho                   =  7.0000e+02
    ecutwfc                   =  7.0000e+01
    ibrav                     = 4
    nat                       = 39
    ntyp                      = 6
    occupations = "smearing"
    smearing    = "fermi-dirac"
    nosym       = .true.
    noinv       = .true.
    lda_plus_u  = .true.
    hubbard_u(2) = 3.56
/

&ELECTRONS
    conv_thr         =  1.00000e-06
    diagonalization  = "david"
    electron_maxstep = 200
    mixing_beta      =  7.00000e-01
    mixing_mode      = "local-TF"
    startingpot      = "atomic"
    startingwfc      = "atomic+random"

/

&IONS
    ion_dynamics  = "bfgs"
/

&CELL
/

K_POINTS {automatic}
