&CONTROL
    calculation = "scf"
    prefix      = "sc"
    restart_mode     = 'from_scratch'
    pseudo_dir  = "../"
    disk_io          = 'high'
    wfcdir           = './'
    wf_collect       = .true.
    tprnfor          = .true.
    tstress          = .true.


/

&SYSTEM
    a                         =  6.21436e+00
    c                         =  2.39280e+01
    degauss                   =  1.00000e-02
    ecutrho                   =  6.0000e+02
    ecutwfc                   =  6.0000e+01
    ibrav                     = 4
    nat                       = 39
    ntyp                      = 6
    lda_plus_u  = .true.
    occupations = "smearing"
    smearing    = "fermi-dirac"
    nosym       = .true.
    noinv       = .true.
    hubbard_u(1) = 3.23
    hubbard_u(2) = 3.36
/

&ELECTRONS
    conv_thr         =  1.00000e-08
    diagonalization  = "david"
    electron_maxstep = 200
    mixing_beta      =  7.00000e-01
    mixing_mode      = "local-TF"
    startingpot      = "atomic"
    startingwfc      = "atomic+random"

/

&IONS
    ions_dynamics  = "bfgs"
/

&CELL
/

K_POINTS {automatic}
